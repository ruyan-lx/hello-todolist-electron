{
  "name": "hello-todolist",
  "version": "1.0.0",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "chcp 65001 && vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build && electron-builder",
    "build:dir": "npm run typecheck && vite build && electron-builder --dir"
  },
  "author": "",
  "license": "ISC",
  "description": "一个简单的待办事项应用",
  "build": {
    "appId": "com.madongmei.hello-todolist",
    "productName": "Hello TodoList",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/assets",
        "to": "electron/assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "~6.0.0",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vue-tsc": "^3.3.7",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "vue": "^3.5.33"
  }
}
